<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="viewModel"
            type="com.mirea.kt.ribo.notescope.viewmodel.SpectrumViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_primary"
        android:padding="@dimen/padding_medium">

        <com.mirea.kt.ribo.notescope.ui.view.SpectrogramLegendView
            android:id="@+id/legendView"
            style="@style/SpectrogramLegend"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_medium"

            app:legendTitle="Spectrogram amplitude"
            app:maxLabel="20 dB"
            app:minLabel="-80 dB"

            app:layout_constraintBottom_toTopOf="@id/spectrogramCard"
            app:layout_constraintStart_toStartOf="@id/spectrogramCard"
            app:layout_constraintEnd_toEndOf="@id/spectrogramCard" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/spectrogramCard"
            style="@style/Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

                <com.mirea.kt.ribo.notescope.ui.view.SpectrogramView
                    android:id="@+id/spectrogramView"
                    style="@style/SpectrogramView"
                    android:layout_width="match_parent"
                    android:layout_height="360dp"
                    android:layout_marginBottom="@dimen/margin_small"
                    android:layout_marginRight="@dimen/margin_small"

                    app:spectrogramMaxDb="20.0"
                    app:spectrogramMinDb="-80.0"
                    app:spectrogramVisualBins="256" />


        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearSpectrogram"
            style="@style/SecondaryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:minWidth="120dp"

            android:text="@string/clear"
            android:onClick="@{() -> viewModel.onClearBufferClicked()}"

            app:layout_constraintTop_toBottomOf="@id/spectrogramCard"
            app:layout_constraintStart_toStartOf="@id/spectrogramCard" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            style="@style/PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:minWidth="120dp"

            android:text="@{!viewModel.isRecordingLive ? `● Start` : `■ Stop`}"

            app:layout_constraintTop_toBottomOf="@id/spectrogramCard"
            app:layout_constraintEnd_toEndOf="@id/spectrogramCard" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>