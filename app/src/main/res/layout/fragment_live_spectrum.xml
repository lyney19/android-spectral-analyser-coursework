<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="viewModel"
            type="io.lyney.notescope.viewmodel.SpectrumViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_primary">

        <io.lyney.notescope.ui.view.MaterialSpectrumView
            android:id="@+id/fftView"
            style="@style/SpectrumView"
            android:layout_width="0dp"
            android:layout_height="300dp"

            app:spectrumSampleRate="@{viewModel.dspConfig.sampleRate()}"
            app:spectrumFrameSize="@{viewModel.dspConfig.frameSize()}"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/infoCard"
            style="@style/Card"
            android:layout_width="320dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="@dimen/margin_large"
            android:layout_marginBottom="@dimen/margin_medium"
            app:cardElevation="0dp"

            app:layout_constraintBottom_toTopOf="@id/fftView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/padding_large">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextWeak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/peak_frequency"
                        android:textSize="@dimen/text_ultra_small" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/margin_small"
                        android:text="@{viewModel.peakFrequency}"
                        android:textColor="@color/primary_bright"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:layout_marginHorizontal="@dimen/margin_small"
                    android:background="@color/border" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextWeak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/musical_note"
                        android:textSize="@dimen/text_ultra_small" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/margin_small"
                        android:text="@{viewModel.musicalNote}"
                        android:textColor="@color/primary_bright"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            style="@style/PrimaryButton"
            android:id="@+id/btnRecord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:layout_marginEnd="@dimen/margin_medium"
            android:minWidth="120dp"
            android:text="@{!viewModel.isRecordingLive ? `● Start` : `■ Stop`}"

            app:layout_constraintTop_toBottomOf="@id/fftView"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>